# Copy to .env and fill in. The READ needs at least one route (a read backend).
#
# Hosted "exhibit" tier: run Track A ONLY (single route -> no picker; GLM-5.2 via
# OpenRouter + zero-data-retention). Track B (self-host VPS) is DEPRECATED for the
# hosted exhibit (see READ_ROUTES.md) — kept for self-hosters who bring their own
# endpoint. If you configure ≥2 routes, the UI shows a picker and the user chooses.

# ============================================================================
# Track A — managed open-weight API (OpenRouter w/ zero-data-retention).
#   Maximum insight: a true frontier-open model. The assembled TEXT transcript
#   transits a third party (no raw media ever) — mitigated by ZDR.
# ============================================================================
ROUTE_A_PROVIDER=openai                         # OpenAI-compatible
ROUTE_A_BASE_URL=https://openrouter.ai/api/v1
ROUTE_A_API_KEY=sk-or-...                        # your OpenRouter key (openrouter.ai/keys)
ROUTE_A_MODEL=z-ai/glm-5.2-20260616             # #1 open-weight, ~4.8¢/read; or deepseek/deepseek-v4-flash-20260423 (~0.3¢)
ROUTE_A_ZDR=1                                     # sends provider:{zdr:true,data_collection:deny}; ALSO enable ZDR at /settings/privacy
# ROUTE_A_THIRD_PARTY=1   ROUTE_A_COLD_START=0   ROUTE_A_ID=managed-api   (defaults)

# ============================================================================
# Track B — self-host on a VPS (vLLM behind an OpenAI-compatible API).
#   DEPRECATED for the hosted exhibit (2026-06-22): the single-GPU-servable model
#   (Qwen3-32B) is a real step down for a nuanced read, and the stronger
#   Qwen3-Next-80B has an open vLLM long-context bug + needs 2 GPUs. Kept for
#   self-hosters / future revival. Uncomment to add it as a 2nd route (the UI then
#   shows the picker). See READ_ROUTES.md § Track B for the RunPod deploy recipe.
# ============================================================================
# ROUTE_B_PROVIDER=openai
# ROUTE_B_BASE_URL=https://api.runpod.ai/v2/<ENDPOINT_ID>/openai/v1
# ROUTE_B_API_KEY=<runpod-key>
# ROUTE_B_MODEL=Qwen/Qwen3-32B-FP8                # fits 1xH100; native 40k context covers our ~33k read
# ROUTE_B_THIRD_PARTY=0   ROUTE_B_COLD_START=1   ROUTE_B_ID=self-host   (defaults)

# Preselected route in the UI when >1 is configured (else: first ready route).
# READ_DEFAULT_ROUTE=managed-api

# --- legacy single-route fallback (used only if no ROUTE_A_*/ROUTE_B_* set) ---
# This is the self-host path: point it at your own endpoint (your VPS, or a local
# Ollama/vLLM), or set FRONTIER_PROVIDER=mock to try the whole flow with no model.
# FRONTIER_PROVIDER=openai        # openai | anthropic | mock
# FRONTIER_BASE_URL=http://YOUR_VPS:8000/v1
# FRONTIER_API_KEY=changeme
# FRONTIER_MODEL=your-model

# --- local media decode ---
VISION_BACKEND=ollama                          # ollama | mock (mock = no Ollama needed)
VISION_MODEL=qwen2.5vl:7b
WHISPER_MODEL=base
DECODE_WORKERS=8

# --- hosted-tier behaviour ---
HOSTED=0                                        # 1 = hosted "exhibit": consent + server-side decode
EPHEMERAL=0                                     # 1 = delete raw media + transcript after the read
