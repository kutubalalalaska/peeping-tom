# Copy to .env and fill in. Deliberately SMALL: keys/hosts, the deployment tier,
# and safety rails. All decode/read tuning lives in code presets —
# DECODE_PROFILE picks the hardware class, the fast/deep read modes are chosen
# in the UI per upload (see mirror/config.py).

# ============================================================================
# The read — ONE remote route (OpenRouter + zero-data-retention recommended).
# Only the assembled TEXT transcript ever crosses; never raw media.
# ROUTE_A_PROVIDER=mock runs the whole flow with no endpoint (flow testing).
# ============================================================================
ROUTE_A_PROVIDER=openai                         # openai (OpenAI-compatible) | anthropic | mock
ROUTE_A_BASE_URL=https://openrouter.ai/api/v1
ROUTE_A_API_KEY=sk-or-...                       # your OpenRouter key (openrouter.ai/keys)
ROUTE_A_MODEL=z-ai/glm-5.2-20260616             # #1 open-weight, ~4.8¢/read
ROUTE_A_ZDR=1                                   # zero-data-retention endpoints only; ALSO enable ZDR at /settings/privacy
# READ_STREAM_REASONING=1                       # stream the model's reasoning to the live "thinking" view
# READ_CONTEXT_TOKENS=262144                    # planning window (default routes GLM onto reliable providers)

# ============================================================================
# Local media decode. DECODE_PROFILE is the ONE tuning knob:
#   gpu (default) — a real GPU / Apple-Silicon host Ollama: 7B VLM, big images
#   cpu           — a CPU VPS (the hosted exhibit): 3B VLM, small images, warm all day
# VISION_MODEL / WHISPER_MODEL / DECODE_WORKERS override single fields if a box
# really needs it — normally leave them unset.
# ============================================================================
# DECODE_PROFILE=gpu
# VISION_BACKEND=ollama                         # ollama | mock (mock = no Ollama needed)
# OLLAMA_HOST=http://ollama:11434               # the bundled service; host Ollama = http://host.docker.internal:11434

# ============================================================================
# Deployment tier.
# ============================================================================
HOSTED=0                                        # 1 = hosted "exhibit": consent gate + rate moat + TTL self-destruct
EPHEMERAL=0                                     # 1 = delete raw media + transcript right after the read

# --- hosted tier: self-destruct (the result-page countdown) ---
READ_TTL_SECONDS=1200                           # read auto-deletes 20 min after it's ready
MAX_JOB_AGE_SECONDS=3600                        # garbage sweep for jobs that never finished
PURGE_INTERVAL_SECONDS=120

# --- hosted tier: abuse moat (no login, no PII) ---
RATE_MAX_PER_SESSION=5
RATE_MAX_PER_IP=20
RATE_WINDOW_SECONDS=86400
COOKIE_SECURE=0                                 # set 1 in production (HTTPS)

# --- ops: admin page + problem alerts (optional; empty = feature off) ---
# ADMIN_PASS enables GET /admin (basic auth) — recent requests + outcomes, live
# jobs, credits, disk. Job-level technical facts only; no IPs, names, content.
# The Telegram pair enables push alerts (failed reads, out-of-credits, 5xx):
# make a bot via @BotFather, message it once, then get your chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates
ADMIN_USER=admin
ADMIN_PASS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_ACTIVITY=1                           # 1 (default) = also ping on normal activity
#                                               # (new upload, finished read); 0 = problems only

# --- upload guard ---
# v0: sized so an accepted chat reads in ONE pass (the in-browser slicer cuts
# bigger exports down — by bytes AND by message volume — before upload).
# MAX_UPLOAD_MB=1536

# --- hosted tier: HTTPS via Caddy (docker-compose.prod.yml) ---
DOMAIN=mirror.example.com                       # your domain; DNS A-record -> the VPS
ACME_EMAIL=you@example.com                      # for Let's Encrypt cert notices
