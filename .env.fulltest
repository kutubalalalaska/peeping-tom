# Preset: FULL end-to-end — native host Ollama decode + the REAL read from your .env
# (ROUTE_A_* stays in .env; this preset only points decode at the host and keeps
# artifacts around longer for inspection).
#   APP_ENV_FILE=.env.fulltest docker compose up app --build
VISION_BACKEND=ollama
OLLAMA_HOST=http://host.docker.internal:11434
MAX_JOB_AGE_SECONDS=86400
