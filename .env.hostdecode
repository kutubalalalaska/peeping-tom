# Preset: REAL local decode on the host's native Ollama (Metal on a Mac), MOCK read.
# For decode-speed and progress-UI work without burning frontier credits.
#   ollama serve   (host)             then:
#   APP_ENV_FILE=.env.hostdecode docker compose up app --build
VISION_BACKEND=ollama
OLLAMA_HOST=http://host.docker.internal:11434
ROUTE_A_PROVIDER=mock
