# Auto-HTTPS reverse proxy for the hosted exhibit. DOMAIN + ACME_EMAIL come from
# .env (passed through docker-compose.prod.yml). Caddy fetches + renews the TLS
# cert automatically once DOMAIN's DNS points here and ports 80/443 are open.
{
	email {$ACME_EMAIL}
}

# Redirect www -> apex (Caddy auto-fetches a cert for www too). Without this block,
# hitting www.<domain> gives a TLS error since no site is configured for it.
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

{$DOMAIN} {
	encode gzip
	# Bound upload size so a huge zip can't exhaust memory (the app reads the
	# upload into RAM). Friends' exports with media are usually well under this.
	request_body {
		max_size 200MB
	}
	reverse_proxy app:8000
}
